# ── Alex.ai environment ─────────────────────────────────────────────
# Copy this file to .env and fill in every value. See README.md §Setup.

# Neon Postgres connection string (free tier) — from console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Login password for the app (you are the only user — pick something long)
ALEX_PASSWORD=change-me-to-a-long-password

# Random secret for signing the session cookie (any long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Google Places API (New) key — console.cloud.google.com (set quota caps! see README)
GOOGLE_PLACES_API_KEY=

# Google AI Studio key for Gemini free tier — aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Brave Search API key (free tier, 2000/mo) — api-dashboard.search.brave.com
BRAVE_SEARCH_API_KEY=

# Optional: override the Gemini model ID (default: gemini-3.1-flash-lite)
# GEMINI_MODEL=gemini-3.1-flash-lite
