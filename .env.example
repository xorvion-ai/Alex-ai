# ── Alex.ai environment ─────────────────────────────────────────────
# Copy this file to .env and fill in the values. Each line says where to
# get the key. Card-free: everything except GOOGLE_PLACES_API_KEY needs
# no payment method at all.

# Neon Postgres connection string (free tier, no card) — console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Login password for the app (you are the only user — pick something long)
ALEX_PASSWORD=change-me-to-a-long-password

# Random secret for signing the session cookie (any long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Google AI Studio key for Gemini free tier (no card) — aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# TomTom Search API key (free 2,500/day, no card) — developer.tomtom.com
TOMTOM_API_KEY=

# Tavily web-verify key (free 1,000/month, no card) — app.tavily.com
TAVILY_API_KEY=

# OPTIONAL: Google Places API (New) — needs a billing account (UPI works in India)
GOOGLE_PLACES_API_KEY=

# Optional: override the Gemini model ID (default: gemini-3.1-flash-lite)
# GEMINI_MODEL=gemini-3.1-flash-lite
